# Ori Configuration
# Copy this file to .env and fill in your API credentials.

# Default model (format: provider:model_name)
# Routing notes:
# - With ORI_API_KEY, either prefixed or unprefixed models work.
# - With exactly one provider-specific key, unprefixed models also work.
# - With multiple provider-specific keys and no ORI_API_KEY, use explicit
#   provider:model strings to avoid ambiguous routing.
ORI_MODEL=openrouter:qwen/qwen3-coder-next

# Global API credentials (used when no per-provider key is set)
# ORI_API_KEY=your-api-key
# ORI_API_BASE=https://openrouter.ai/api/v1

# Per-provider credentials (override global for specific providers)
# Example single-provider setup:
# ORI_OPENAI_API_KEY=sk-xxx
# ORI_OPENAI_API_BASE=https://api.openai.com/v1
#
# Example multi-provider setup:
# ORI_OPENROUTER_API_KEY=sk-or-xxx
# ORI_OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# Fallback models (comma-separated, tried in order when primary fails)
# Prefer explicit provider:model entries for predictable routing.
# ORI_FALLBACK_MODELS=openai:gpt-4o,anthropic:claude-sonnet

# Transport format
ORI_API_FORMAT=completion

# Runtime limits
ORI_MAX_STEPS=50
ORI_MAX_TOKENS=1024
# ORI_MODEL_TIMEOUT_SECONDS=120

# Data directory
# ORI_HOME=~/.ori

# Verbosity (0=normal, 1=debug, 2=trace)
# ORI_VERBOSE=0

# Doris connection settings
DORIS_FE_HOST=127.0.0.1
DORIS_FE_PORT=9030
DORIS_USER=root
# DORIS_PASSWORD=
# DORIS_DATABASE=
DORIS_CONNECT_TIMEOUT=10
DORIS_QUERY_TIMEOUT=30

# File tool notes
# - fs.read reads regular text files only.
# - fs.read rejects files larger than 10 MiB and truncates output at 64 KiB.
# - fs.edit rejects files larger than 1 MiB.
